# Required: Google Gemini API key
GEMINI_API_KEY=your-gemini-api-key

# Optional: Gemini model to use (default: gemini-3.1-flash-lite-preview)
# GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Required: URL of the remote MCP server (StreamableHTTP transport).
# x402 payments are handled automatically when the server returns HTTP 402.
REMOTE_MCP_URL=https://svm402.com/mcp

# Required: Solana wallet private key (base58-encoded, used for x402 payments and trading)
SOLANA_PRIVATE_KEY=your-base58-private-key

# Optional: Custom Solana RPC URL (used by the x402 SDK and dex-trader-mcp to avoid public rate limits)
# SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional: Path to dex-trader-mcp dist/index.js (enables Jupiter DEX trading tools)
# DEX_TRADER_MCP_PATH=/path/to/dex-trader-mcp/dist/index.js

# Optional: Path to dex-screener-mcp dist/index.js (enables DexScreener token discovery tools)
# DEX_SCREENER_MCP_PATH=/path/to/dex-screener-mcp/dist/index.js

# Optional: Path to dex-rugcheck-mcp dist/index.js (enables RugCheck token safety analysis)
# DEX_RUGCHECK_MCP_PATH=/path/to/dex-rugcheck-mcp/dist/index.js

# Optional: Path to solana-rpc-mcp dist/index.js (enables direct Solana RPC blockchain queries)
# SOLANA_RPC_MCP_PATH=/path/to/solana-rpc-mcp/dist/index.js

# Optional: Jupiter API base URL (forwarded to dex-trader-mcp)
# JUPITER_API_BASE=https://api.jup.ag/swap/v1

# Optional: Jupiter API key (forwarded to dex-trader-mcp)
# JUPITER_API_KEY=your-jupiter-api-key

# Optional: Telegram bot token from @BotFather. Enables the Telegram interface when set.
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Optional: Telegram chat ID of the authorised user.
# When set, the bot will ONLY respond to this chat and reject all others.
# Strongly recommended — without this, the bot accepts messages from any Telegram user.
# Obtain your chat ID by messaging @userinfobot on Telegram.
# TELEGRAM_CHAT_ID=123456789
